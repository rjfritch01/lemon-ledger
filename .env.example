# =============================================================================
# Lemon Ledger – local development environment variables
#
# Copy this file to .env and fill in values before running `just up`.
# The real .env is gitignored and must NEVER be committed.
#
# Production secrets are managed by Doppler — never committed, never stored
# in .env files on servers or CI.
# =============================================================================

# --- Postgres 16 ---
POSTGRES_DB=lemon_ledger
POSTGRES_USER=lemon
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Redis 7 ---
REDIS_PORT=6379
